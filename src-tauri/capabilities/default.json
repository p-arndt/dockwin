{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the dockwin main window. App-defined commands (engine_*, container_*, image_*) are accessible without explicit ACL entries; this grants the core/plugin permissions the GUI relies on.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-is-visible",
    "core:app:default",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "log:default",
    "opener:default",
    "opener:allow-open-url",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "opener:default",
    "opener:allow-open-url",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    }
  ]
}
