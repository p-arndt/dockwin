{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dockwin",
  "version": "0.1.3",
  "identifier": "dev.dockwin.gui",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm sidecar"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "dockwin",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "dockwin contributors",
    "category": "DeveloperTool",
    "shortDescription": "Lightweight Docker Desktop alternative for Windows 11",
    "longDescription": "dockwin runs stock dockerd inside a dedicated minimal WSL2 distro and gives you a thin native GUI/CLI over it. No bloat, no telemetry, no background service.",
    "license": "MIT OR Apache-2.0",
    "externalBin": ["binaries/dockwin"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/p-arndt/dockwin/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCRDlDQzQyQTczOTlFNTYKUldSV25qbW5Rc3pabTgyWmg0ODhqekNPWGFXbm5RMm1IZ2QxNkN1WGM2Q3FpTnFzMjZuY0swTUYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
